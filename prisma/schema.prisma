generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
  VOLUNTEER
}

enum CampaignCategory {
  medical
  emergency
  education
  disaster
  family
  food
  shelter
  orphan
  women
  community
}

enum CampaignStatus {
  pending
  active
  verified
  closed
  completed
}

enum DonationStatus {
  pending
  paid
  failed
  refunded
}

enum ItemCategory {
  clothes
  food
  books
  furniture
  medicine
  electronics
  other
}

enum ItemCondition {
  new
  used
  excellent
  fair
}

enum PickupStatus {
  pending
  assigned
  picked_up
  delivered
  cancelled
}

enum InquiryStatus {
  pending
  responded
  resolved
  archived
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  phone    String?
  avatar   String?

  role Role @default(USER)

  campaigns     Campaign[]
  donations     Donation[]
  itemDonations ItemDonation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// CAMPAIGN (MAIN MODEL)
//////////////////////////////////////////////////////

model Campaign {
  id String @id @default(cuid())

  title           String
  slug            String           @unique
  description     String
  story           String
  category        CampaignCategory
  status          CampaignStatus   @default(pending)
  goalAmount      Float
  collectedAmount Float            @default(0)
  image           String?
  startDate       DateTime         @default(now())
  endDate         DateTime
  contributor     Int              @default(0)
  featured        Boolean          @default(false)

  creatorId String
  creator   User @relation(fields: [creatorId], references: [id])

  tags          String[] @default([])
  acceptedItems String[]
  updates       Json?

  // Completion fields — populated when admin marks campaign as completed
  successStory  String?
  successImages String[] @default([])
  completedAt   DateTime?

  donations     Donation[]
  itemDonations ItemDonation[]

  translations CampaignTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, status])
  @@index([creatorId])
  @@index([slug])
}

model CampaignTranslation {
  id           String  @id @default(cuid())
  campaignId   String
  lang         String
  title        String
  description  String
  story        String
  successStory String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, lang])
  @@index([lang])
}

//////////////////////////////////////////////////////
// DONATION
//////////////////////////////////////////////////////

model Donation {
  id String @id @default(cuid())

  amount Float

  transactionId String? @unique // ✅ nullable + unique

  donorName  String
  donorEmail String?

  anonymous Boolean @default(false)

  status DonationStatus @default(pending)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  donorId String?
  donor   User? @relation(fields: [donorId], references: [id])

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

//////////////////////////////////////////////////////
// PAYMENT (NEW)
//////////////////////////////////////////////////////

model Payment {
  id              String   @id @default(cuid())
  amount          Int      // in cents (e.g. 1000 = $10.00)
  currency        String   @default("usd")
  stripePaymentId String   @unique
  status          String   @default("pending")

  // 🔥 Link to Donation (1:1)
  donationId String   @unique
  donation   Donation @relation(fields: [donationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ITEM DONATION (OPTIONAL FEATURE)
//////////////////////////////////////////////////////

model ItemDonation {
  id String @id @default(cuid())

  itemName  String?
  category  ItemCategory
  quantity  Int
  condition ItemCondition

  description String?
  photos      String[]

  pickupAddress String
  preferredDate DateTime
  preferredTime String

  contactName  String
  contactPhone String

  status PickupStatus @default(pending)

  donorId String
  donor   User @relation(fields: [donorId], references: [id])

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Banner {
  id          String   @id @default(cuid())
  short_title String?
  title       String
  description String?
  photo       String

  isActive    Boolean  @default(true)
  order       Int      @default(0)

  translations BannerTranslation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BannerTranslation {
  id          String  @id @default(cuid())
  bannerId    String
  lang        String
  short_title String?
  title       String
  description String?

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bannerId, lang])
  @@index([lang])
}

model Charity {
  id          String   @id @default(cuid())
  active      Boolean  @default(true)
  name        String
  logo        String
  banner      String?
  verified    Boolean  @default(false)
  mission     String?
  description String
  website     String?
  address     String?
  email       String?
  phone       String?

  translations CharityTranslation[]
  inquiries    CharityInquiry[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CharityInquiry {
  id        String         @id @default(cuid())
  charityId String
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    InquiryStatus  @default(pending)

  charity Charity @relation(fields: [charityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([charityId])
  @@index([status])
  @@index([createdAt])
}

model CharityTranslation {
  id          String  @id @default(cuid())
  charityId   String
  lang        String
  name        String
  mission     String?
  description String
  address     String?

  charity Charity @relation(fields: [charityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([charityId, lang])
  @@index([lang])
}